{"pageProps":{"note":{"id":"nzaIGEJIdgvpLwJH7ymKe","title":"Books","desc":"","updated":1660641004296,"created":1628105448207,"custom":{},"fname":"books","type":"note","vault":{"fsPath":"vault"},"contentHash":"8f8292f9284152fd2e55fdfad103a5ff","links":[],"anchors":{"open-source":{"type":"header","text":"Open Source","value":"open-source","line":8,"column":0,"depth":2},"science":{"type":"header","text":"Science","value":"science","line":13,"column":0,"depth":2},"society":{"type":"header","text":"Society","value":"society","line":19,"column":0,"depth":2},"technology":{"type":"header","text":"Technology","value":"technology","line":23,"column":0,"depth":2}},"children":[],"parent":"RnFytXiQFrHboGg6","data":{}},"body":"<h1 id=\"books\">Books<a aria-hidden=\"true\" class=\"anchor-heading icon-link\" href=\"#books\"></a></h1>\n<h2 id=\"open-source\">Open Source<a aria-hidden=\"true\" class=\"anchor-heading icon-link\" href=\"#open-source\"></a></h2>\n<ul>\n<li><a href=\"https://www.oreilly.com/library/view/the-cathedral/0596001088\">The Cathedral &#x26; the Bazaar</a>, by Eric S. Raymond</li>\n<li><a href=\"https://www.goodreads.com/en/book/show/54140556-working-in-public\">Working in Public: The Making and Maintenance of Open Source Software</a>, by Nadia Eghbal</li>\n</ul>\n<h2 id=\"science\">Science<a aria-hidden=\"true\" class=\"anchor-heading icon-link\" href=\"#science\"></a></h2>\n<ul>\n<li><a href=\"https://openlibrary.org/works/OL20152899W/An_Elegant_Defense_The_Extraordinary_New_Science_of_the_Immune_System\">An Elegant Defense: The Extraordinary New Science of the Immune System</a>, by Matt Richtel</li>\n<li><a href=\"https://www.goodreads.com/book/show/57423646-immune\">Immune: A Journey into the Mysterious System that Keeps You Alive</a>, by Philipp Dettmer</li>\n<li><a href=\"https://openlibrary.org/books/OL26359464M/The_Gene\">The Gene: An Intimate History</a>, by Siddhartha Mukherjee</li>\n</ul>\n<h2 id=\"society\">Society<a aria-hidden=\"true\" class=\"anchor-heading icon-link\" href=\"#society\"></a></h2>\n<ul>\n<li><a href=\"https://www.takingstockofshock.com/\">Taking Stock of Shock</a>, by Kristen Ghodsee and Mitchell A. Orenstein</li>\n</ul>\n<h2 id=\"technology\">Technology<a aria-hidden=\"true\" class=\"anchor-heading icon-link\" href=\"#technology\"></a></h2>\n<ul>\n<li><a href=\"https://www.goodreads.com/book/show/15927030-computer-security\">Computer Security: Art and Science</a>, by Matt Bishop</li>\n<li><a href=\"https://www.goodreads.com/book/show/27272504-overcomplicated\">Overcomplicated: Technology at the Limits of Comprehension</a>, by Samuel Arbesman</li>\n<li><a href=\"https://www.goodreads.com/en/book/show/1660754.The_Psychology_of_Computer_Programming\">The Psychology of Computer Programming</a>, by Gerald Weinberg</li>\n<li><a href=\"https://www.goodreads.com/book/show/23627482-your-code-as-a-crime-scene\">Your Code As a Crime Scene: Use Forensic Techniques to Arrest Defects, Bottlenecks, and Bad Design in Your Programs</a>, by Adam Tornhill</li>\n</ul>","noteIndex":{"id":"RnFytXiQFrHboGg6","title":"Root","desc":"","updated":1628096509181,"created":1627503796059,"custom":{"nav_order":0,"permalink":"/"},"fname":"root","type":"note","vault":{"fsPath":"vault"},"contentHash":"206dff34b187a0c86690231f5ab89590","links":[],"anchors":{"welcome-to-dendron":{"type":"header","text":"Welcome to Dendron","value":"welcome-to-dendron","line":8,"column":0,"depth":2},"references":{"type":"header","text":"References","value":"references","line":14,"column":0,"depth":2}},"children":["dkfh94o63alb7tbsand0x7y","nzaIGEJIdgvpLwJH7ymKe","wbzvfnfjnylw5itg6fuu72z","4yhbwwlogzhmx2hx0hcerss","kygx0n3whew1nclpl9t2yez","6PLkATyxbebndxZN16uIu","TPJzHuR1eliPxlkDoCzkB","14k92nioe3867mf7jurdcx2","CsGGFbjhwTVGO62G","cjk8rvm17udhe76byyuy2uo","uBtE3AOKicb36PDES0O7f","89akqrwd8seeq56c76udd1j","GbJ3FISGIQDPWGfsK9yb2","oo6bpdb8enqslzc0l1bneif","2zzdvob2h82f9c1qt2pwtmk","Otb17Tvp1g9j7aUs1drP9","epeaq0sf7bp5w7cospgqvvo","9t2cbpqc1vofuqkw